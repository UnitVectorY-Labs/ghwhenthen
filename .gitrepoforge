name: ghwhenthen
default_branch: main
config:
  description: "A lightweight, configuration-driven service that consumes GitHub webhook events from Google Cloud Pub/Sub, evaluates declarative rules against message attributes and payloads, and executes ordered GitHub GraphQL actions."
  license: MIT
  language: go
  release: docker-go
  justfile: true
  codecov:
    enabled: false
  docs:
    enabled: true
    domain: ghwhenthen.unitvectorylabs.com